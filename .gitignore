# Archive files
*.zip
*.tar.gz
*.rar

# Screenshots and images (unless specifically needed)
screenshots/
*.png
*.jpg
*.jpeg
*.gif
*.svg

# Local development server logs
server.log
access.log
error.log

# Node modules
node_modules/
# Ambiente
.env
